modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_xai:1.0.0"]

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
PORT = "5000"
DISCORD_REDIRECT_URI = "https://6c9977cc-588a-4fd1-a063-8f1e08e6cac0-00-12zgrazfokc8j.pike.replit.dev/api/auth/callback"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Discord Bot"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd botdash && npm run dev -- --port 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "Discord Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd bot && node index.js"

[workflows.workflow.metadata]
outputType = "console"

[nix]
channel = "stable-25_05"
